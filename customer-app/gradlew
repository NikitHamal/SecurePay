#!/usr/bin/env sh
set -eu

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GRADLE_VERSION=8.9
GRADLE_HOME="$APP_HOME/.gradle/gradle-$GRADLE_VERSION"

if [ -x "$GRADLE_HOME/bin/gradle" ]; then
  exec "$GRADLE_HOME/bin/gradle" "$@"
fi

mkdir -p "$APP_HOME/.gradle"
ZIP="$APP_HOME/.gradle/gradle-$GRADLE_VERSION-bin.zip"
if [ ! -f "$ZIP" ]; then
  curl -fsSL "https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip" -o "$ZIP"
fi
unzip -q -o "$ZIP" -d "$APP_HOME/.gradle"
exec "$GRADLE_HOME/bin/gradle" "$@"
