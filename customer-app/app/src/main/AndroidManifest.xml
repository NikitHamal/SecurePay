<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Allow the lock overlay to launch the dialer for emergency calls. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SecurePayCustomer">

        <!-- Launcher activity hosting the Compose UI. android:icon intentionally
             omitted to avoid referencing missing mipmap/drawable resources. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SecurePayCustomer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Device Policy Controller (DPC) receiver. Enforces the financing
             payment policy: force-lock on overdue, restrict debugging, etc. -->
        <receiver
            android:name=".admin.SecurePayDeviceAdminReceiver"
            android:description="@string/device_admin_description"
            android:label="@string/device_admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
