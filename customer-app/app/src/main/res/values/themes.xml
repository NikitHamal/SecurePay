<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. The Compose M3 theme drives runtime colors;
         this keeps the splash/window background charcoal to avoid white flashes. -->
    <style name="Theme.TBUser" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/charcoal</item>
        <item name="android:statusBarColor">@color/charcoal</item>
        <item name="android:navigationBarColor">@color/charcoal</item>
    </style>
</resources>
