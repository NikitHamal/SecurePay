# Local development only. Never commit production values.
JWT_SECRET=replace-with-a-long-random-secret
HMAC_SECRET=replace-with-a-different-long-random-secret
# Optional comma-separated Google account numeric user IDs used for EFRP if dealer-specific IDs are not configured.
FRP_ACCOUNT_IDS=
# Optional floor for old TB User apps. Devices below this should update immediately.
CUSTOMER_APP_MIN_SUPPORTED_VERSION_CODE=18
ALLOW_DEMO_SEED=false

# Didit KYC integration
DIDIT_API_KEY=replace-with-your-didit-api-key
DIDIT_WEBHOOK_SECRET=replace-with-your-didit-webhook-secret
DIDIT_WORKFLOW_ID=replace-with-your-approved-workflow-id
DIDIT_CALLBACK_URL=https://your-dashboard.example/api/webhooks/didit

# Deployment/version and Firebase Cloud Messaging server configuration
APP_BUILD_VERSION=2026.07.10
FCM_PROJECT_ID=replace-with-your-firebase-project-id
FCM_SERVICE_ACCOUNT_EMAIL=replace-with-service-account-email
FCM_SERVICE_ACCOUNT_PRIVATE_KEY=replace-with-pkcs8-private-key

# Paystack payment integration (GHS mobile money + cards)
# Create at https://dashboard.paystack.com/#/settings/developer
# Test key starts with sk_test_, live key starts with sk_live_
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
